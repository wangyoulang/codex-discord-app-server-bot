APP_ENV=development
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_SYNC_GUILD_COMMANDS=true

DATABASE_URL=sqlite+aiosqlite:///./state/app.db
STATE_DIR=./state
ARTIFACT_DIR=./artifacts
LOG_DIR=./logs
LOG_LEVEL=INFO

CODEX_BIN=codex
# 可选：仅当你想让 bot 使用指定的 Codex home 时再设置。
# 不设置时，bot 会直接复用当前本机 `codex` 默认读取的 config.toml。
# CODEX_HOME=/path/to/your/codex-home
# 可选：仅透传给 `codex app-server` 子进程的代理配置。
# 如果你的 Codex provider 依赖代理访问第三方网关，请在这里显式配置。
# CODEX_HTTP_PROXY=http://127.0.0.1:7890
# CODEX_HTTPS_PROXY=http://127.0.0.1:7890
# CODEX_ALL_PROXY=socks5://127.0.0.1:7890
# CODEX_NO_PROXY=127.0.0.1,localhost
WORKER_IDLE_TIMEOUT_SECONDS=900

# 需要在 Discord Developer Portal 中开启：
# 1. MESSAGE CONTENT INTENT
# 2. GUILD MEMBERS INTENT（如果后续要做更细权限控制）

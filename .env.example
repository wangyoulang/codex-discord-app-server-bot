APP_ENV=development
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_SYNC_GUILD_COMMANDS=true

DATABASE_URL=sqlite+aiosqlite:///./state/app.db
STATE_DIR=./state
ARTIFACT_DIR=./artifacts
LOG_DIR=./logs
LOG_LEVEL=INFO

ENABLE_CODEX_COMMAND=true
ENABLE_CLAUDE_COMMAND=false

CODEX_BIN=codex
# 可选：仅当你想让 bot 使用指定的 Codex home 时再设置。
# 不设置时，bot 会直接复用当前本机 `codex` 默认读取的 config.toml。
# CODEX_HOME=/path/to/your/codex-home

CLAUDE_BIN=claude
CLAUDE_MODEL=sonnet
CLAUDE_EFFORT=medium
CLAUDE_PERMISSION_MODE=default
CLAUDE_SETTING_SOURCES=user,project,local
CLAUDE_INCLUDE_PARTIAL_MESSAGES=true

# Claude 默认走 API Key 模式。若接第三方网关，可同时设置 CLAUDE_BASE_URL。
CLAUDE_AUTH_MODE=api_key
CLAUDE_API_KEY=
CLAUDE_BASE_URL=
CLAUDE_AUTH_TOKEN=
CLAUDE_CUSTOM_HEADERS_JSON=

# 仅在 Bedrock / Vertex 模式下需要。
CLAUDE_USE_BEDROCK=false
CLAUDE_BEDROCK_BASE_URL=
CLAUDE_SKIP_BEDROCK_AUTH=false

CLAUDE_USE_VERTEX=false
CLAUDE_VERTEX_BASE_URL=
CLAUDE_VERTEX_PROJECT_ID=
CLAUDE_VERTEX_REGION=
CLAUDE_SKIP_VERTEX_AUTH=false

WORKER_IDLE_TIMEOUT_SECONDS=900

# 需要在 Discord Developer Portal 中开启：
# 1. MESSAGE CONTENT INTENT
# 2. GUILD MEMBERS INTENT（如果后续要做更细权限控制）

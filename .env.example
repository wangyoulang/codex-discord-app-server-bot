APP_ENV=development
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_SYNC_GUILD_COMMANDS=true

DATABASE_URL=sqlite+aiosqlite:///./state/app.db
STATE_DIR=./state
ARTIFACT_DIR=./artifacts
LOG_DIR=./logs
LOG_LEVEL=INFO

CODEX_BIN=codex
CODEX_HOME=./runtime/codex-home
CODEX_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=high
CODEX_SANDBOX_MODE=workspace-write
CODEX_APPROVAL_POLICY=on-request
CODEX_SERVICE_TIER=fast
CODEX_DEFAULT_PERSONALITY=pragmatic
WORKER_IDLE_TIMEOUT_SECONDS=900

# 需要在 Discord Developer Portal 中开启：
# 1. MESSAGE CONTENT INTENT
# 2. GUILD MEMBERS INTENT（如果后续要做更细权限控制）
